<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EasySave.GUI.App"
             xmlns:local="using:EasySave.GUI"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5F8FF" Offset="0" />
                    <GradientStop Color="#E6EEF9" Offset="0.45" />
                    <GradientStop Color="#D8E3F3" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="FontFamily" Value="Tahoma, Verdana, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#17315C" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#7E9BC8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BoxShadow" Value="0 1 0 #FDFEFF, 0 6 18 #223B6940" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFDF7" Offset="0" />
                    <GradientStop Color="#F0F5FE" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="#9FB6DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#163A73" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#59739F" />
        </Style>
        <Style Selector="TextBlock.metric-value">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0F3E86" />
        </Style>
        <Style Selector="TextBlock.metric-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#6782AC" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFDF9" Offset="0" />
                    <GradientStop Color="#F9EAC1" Offset="0.52" />
                    <GradientStop Color="#EFD680" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="#8B6E1F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#24354E" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#FFE99A" Offset="0.52" />
                    <GradientStop Color="#F6D25D" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#EFCB5A" Offset="0" />
                    <GradientStop Color="#FAE8A7" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="TextBox, ComboBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#7F9DB9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#17315C" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F5FAFF" Offset="0" />
                    <GradientStop Color="#D6E4FA" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="#5D7FAF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1A3F7A" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#F8FBFF" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#FFFEFB" />
            <Setter Property="BorderBrush" Value="#8CA7CE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBoxItem:selected Border.card">
            <Setter Property="BorderBrush" Value="#2E6BCE" />
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FDFEFF" Offset="0" />
                    <GradientStop Color="#DCEBFF" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Application.Styles>
</Application>
