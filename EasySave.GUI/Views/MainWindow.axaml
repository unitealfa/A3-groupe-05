<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1380" d:DesignHeight="860"
        x:Class="EasySave.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1380"
        Height="860"
        MinWidth="1140"
        MinHeight="760"
        Title="EasySave 2.0">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="14">
        <Border Grid.Row="0"
                Margin="0,0,0,12"
                CornerRadius="10"
                BorderBrush="#1B3F7B"
                BorderThickness="1"
                BoxShadow="0 8 20 #244A8833">
            <Grid RowDefinitions="Auto,Auto">
                <Border CornerRadius="10,10,0,0"
                        Padding="20,14,20,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0F4FB5" Offset="0" />
                            <GradientStop Color="#2E83EA" Offset="0.55" />
                            <GradientStop Color="#77B8FA" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding Texts[AppTitle]}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding Texts[GuiSubtitle]}" FontSize="13" Foreground="#EAF4FF"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="#F6FBFF33"
                                BorderBrush="#CBE4FF88"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="14,8"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Windows XP Professional" FontSize="12" FontWeight="Bold" Foreground="#FFFFFF"/>
                                <TextBlock Text="EasySave Control Center" FontSize="11" Foreground="#E5F2FF"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#F8FBFF"
                        Padding="16,12"
                        CornerRadius="0,0,10,10">
                    <Grid ColumnDefinitions="*,*,*,*,*">
                        <Border Classes="card" Margin="0,0,10,0" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="metric-label" Text="Configured jobs"/>
                                <TextBlock Classes="metric-value" Text="{Binding TotalJobsCount}"/>
                                <TextBlock Classes="muted" Text="Unlimited backup definitions"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="card" Margin="0,0,10,0" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="metric-label" Text="Running states"/>
                                <TextBlock Classes="metric-value" Text="{Binding ActiveStatesCount}"/>
                                <TextBlock Classes="muted" Text="Current active executions"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Classes="card" Margin="0,0,10,0" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="metric-label" Text="Finished states"/>
                                <TextBlock Classes="metric-value" Text="{Binding FinishedStatesCount}"/>
                                <TextBlock Classes="muted" Text="Completed successfully"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Classes="card" Margin="0,0,10,0" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="metric-label" Text="Blocked states"/>
                                <TextBlock Classes="metric-value" Text="{Binding BlockedStatesCount}"/>
                                <TextBlock Classes="muted" Text="Business software detected"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Classes="card" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="metric-label" Text="Error states"/>
                                <TextBlock Classes="metric-value" Text="{Binding ErrorStatesCount}"/>
                                <TextBlock Classes="muted" Text="Execution or encryption issues"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="panel" Margin="0,0,0,12" Padding="14,12">
            <Grid ColumnDefinitions="280,*,300" ColumnSpacing="14">
                <Border Classes="card" Padding="14,12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-title" Text="Quick actions"/>
                        <TextBlock Classes="muted" Text="Launch backups and refresh the current desktop state." TextWrapping="Wrap"/>
                        <Separator Margin="0,6,0,4"/>
                        <Button Content="{Binding Texts[RefreshJobs]}" Command="{Binding RefreshJobsCommand}" HorizontalAlignment="Stretch"/>
                        <Button Content="{Binding Texts[RunJob]}" Command="{Binding RunSelectedJobCommand}" HorizontalAlignment="Stretch"/>
                        <Button Content="{Binding Texts[RunAllJobs]}" Command="{Binding RunAllJobsCommand}" HorizontalAlignment="Stretch"/>
                        <Button Content="{Binding Texts[RefreshState]}" Command="{Binding RefreshStatesCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="16,14">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="section-title" Text="Backup workspace"/>
                        <TextBlock Classes="muted"
                                   Text="Create, launch and supervise complete or differential jobs from a single control surface."
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="card" Padding="14,12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-title" Text="General profile"/>
                        <TextBlock Classes="muted" Text="{Binding CryptoSoftPath}" TextWrapping="Wrap"/>
                        <Separator Margin="0,6,0,4"/>
                        <TextBlock FontWeight="Bold" Text="Log format"/>
                        <TextBlock Classes="muted" Text="{Binding SelectedLogFormat}"/>
                        <TextBlock FontWeight="Bold" Text="Language"/>
                        <TextBlock Classes="muted" Text="{Binding SelectedLanguage}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Classes="panel" Padding="10">
            <TabControl>
                <TabItem Header="{Binding Texts[JobsTab]}">
                    <Grid Margin="10" ColumnDefinitions="2.1*,1.1*" ColumnSpacing="14">
                        <Border Classes="card" Padding="0">
                            <Grid RowDefinitions="Auto,*">
                                <Border Background="#EAF2FD"
                                        BorderBrush="#B2C8E8"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="7,7,0,0"
                                        Padding="14,10">
                                    <Grid ColumnDefinitions="2.2*,2.2*,2.2*,0.9*">
                                        <TextBlock Text="Name" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="Source" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="Target" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="Type" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                                <ListBox Grid.Row="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemsSource="{Binding Jobs}"
                                         SelectedItem="{Binding SelectedJob}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="card" Margin="8,8,8,0" Padding="14,12">
                                                <Grid ColumnDefinitions="2.2*,2.2*,2.2*,0.9*">
                                                    <StackPanel Grid.Column="0" Spacing="2">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                        <TextBlock Classes="muted" Text="Backup job"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding SourceDirectory}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TargetDirectory}" TextWrapping="Wrap"/>
                                                    <Border Grid.Column="3"
                                                            HorizontalAlignment="Left"
                                                            Background="#DDEBFF"
                                                            BorderBrush="#96B2DA"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Padding="10,4">
                                                        <TextBlock Text="{Binding Type}" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="section-title" Text="Selected job"/>
                                    <TextBlock Text="{Binding SelectedJob.Name, FallbackValue=No job selected}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Classes="muted" Text="{Binding SelectedJob.SourceDirectory}" TextWrapping="Wrap"/>
                                    <TextBlock Classes="muted" Text="{Binding SelectedJob.TargetDirectory}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section-title" Text="Execution shortcuts"/>
                                    <TextBlock Classes="muted"
                                               Text="Use single-job launch for focused operations or run the entire queue in sequence."
                                               TextWrapping="Wrap"/>
                                    <Button Content="{Binding Texts[RunJob]}" Command="{Binding RunSelectedJobCommand}" HorizontalAlignment="Stretch"/>
                                    <Button Content="{Binding Texts[RunAllJobs]}" Command="{Binding RunAllJobsCommand}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Texts[CreateJob]}">
                    <Grid Margin="14" ColumnDefinitions="2*,1*" ColumnSpacing="14">
                        <Border Classes="card" Padding="18,16">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                                  ColumnDefinitions="180,*,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Classes="section-title" Text="Create a new backup definition"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[JobName]}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding JobName}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[SourceDirectory]}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SourceDirectory}"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="{Binding Texts[Browse]}" Click="SourceBrowse_Click"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[TargetDirectory]}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TargetDirectory}"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="{Binding Texts[Browse]}" Click="TargetBrowse_Click"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[BackupType]}"/>
                                <ComboBox Grid.Row="4"
                                          Grid.Column="1"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding BackupTypeOptions}"
                                          SelectedValue="{Binding SelectedBackupType}"
                                          SelectedValueBinding="{Binding Value}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="{Binding Texts[CreateJob]}" Command="{Binding AddJobCommand}"/>
                                    <Button Content="{Binding Texts[RefreshJobs]}" Command="{Binding RefreshJobsCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="section-title" Text="Design guidance"/>
                                    <TextBlock Classes="muted"
                                               Text="Use a short job name, select an exact source folder, then point to the destination root that should receive the replicated tree."
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="section-title" Text="Backup behavior"/>
                                    <TextBlock Text="Complete" FontWeight="Bold"/>
                                    <TextBlock Classes="muted" Text="Copies the full source tree." TextWrapping="Wrap"/>
                                    <TextBlock Text="Differential" FontWeight="Bold" Margin="0,6,0,0"/>
                                    <TextBlock Classes="muted" Text="Copies only missing or changed files." TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Texts[SettingsTab]}">
                    <Grid Margin="14" ColumnDefinitions="2.2*,1*" ColumnSpacing="14">
                        <Border Classes="card" Padding="18,16">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*"
                                  ColumnDefinitions="220,*"
                                  RowSpacing="12"
                                  ColumnSpacing="12">
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Classes="section-title" Text="General settings"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[LanguageLabel]}"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding LanguageOptions}" SelectedValue="{Binding SelectedLanguage}" SelectedValueBinding="{Binding Value}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[LogFormatLabel]}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding LogFormatOptions}" SelectedValue="{Binding SelectedLogFormat}" SelectedValueBinding="{Binding Value}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Label}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[EncryptedExtensionsLabel]}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EncryptedExtensionsText}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[BusinessSoftwareLabel]}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding BusinessSoftwareProcessesText}"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[CryptoSoftPathLabel]}"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CryptoSoftPath}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="{Binding Texts[CryptoKeyLabel]}"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CryptoKey}"/>

                                <Button Grid.Row="7" Grid.Column="1" Content="{Binding Texts[SaveSettings]}" Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="section-title" Text="Encryption policy"/>
                                    <TextBlock Classes="muted"
                                               Text="Only files matching the configured extensions are sent through CryptoSoft. Use semicolons such as .txt;.docx;.zip."
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="section-title" Text="Business software stop rule"/>
                                    <TextBlock Classes="muted"
                                               Text="If one of the configured process names is detected, EasySave finishes the current file, logs the interruption and stops the sequence."
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Texts[StateTab]}">
                    <Grid Margin="14" ColumnDefinitions="2.2*,1*" ColumnSpacing="14">
                        <Border Classes="card" Padding="0">
                            <Grid RowDefinitions="Auto,*">
                                <Border Background="#EAF2FD"
                                        BorderBrush="#B2C8E8"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="7,7,0,0"
                                        Padding="14,10">
                                    <Grid ColumnDefinitions="1.6*,0.9*,0.8*,0.8*,2.1*,2.1*">
                                        <TextBlock Text="Job" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="State" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="2" Text="Progress" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="3" Text="Remaining" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="4" Text="Current source" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="5" Text="Current target" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" ItemsSource="{Binding States}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="card" Margin="8,8,8,0" Padding="14,12">
                                                <Grid ColumnDefinitions="1.6*,0.9*,0.8*,0.8*,2.1*,2.1*">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                    <Border Grid.Column="1"
                                                            HorizontalAlignment="Left"
                                                            Background="#E6F0FE"
                                                            BorderBrush="#9FB8DE"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Padding="10,4">
                                                        <TextBlock Text="{Binding State}" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding Progression}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding RemainingFiles}"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding CurrentSourceFilePath}" TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding CurrentDestinationFilePath}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <Border Classes="card" Padding="16,14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section-title" Text="Runtime monitor"/>
                                    <TextBlock Classes="muted"
                                               Text="Refresh the state list to inspect progression, remaining files and the active source or destination currently processed."
                                               TextWrapping="Wrap"/>
                                    <Button Content="{Binding Texts[RefreshState]}" Command="{Binding RefreshStatesCommand}" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="14,10"
                CornerRadius="8"
                BorderBrush="#7E9BC8"
                BorderThickness="1"
                Background="#EEF5FF">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding Texts[StatusLabel]}" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Margin="12,0,0,0" Text="{Binding StatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>

</Window>
