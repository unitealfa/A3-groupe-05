@startuml
start
:Validate backup job;
if (Source exists?) then (yes)
  :Create target directory;
  :Enumerate source files recursively;
  if (Backup type?) then (Complete)
    :Plan all files;
  else (Differential)
    :Plan missing or newer files;
  endif
  :Write state Active;
  while (File remaining?) is (yes)
    :Update state current file;
    if (Copy succeeds?) then (yes)
      :Write success log;
    else (no)
      :Write error log;
      :Mark state Error;
    endif
    :Update progress state;
  endwhile (no)
  :Write final state Finished or Error;
else (no)
  :Return validation error;
endif
stop
@enduml
